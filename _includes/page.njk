---
layout: base.njk
---

{# Toplevel pages with title, content, etc #}

{% if title %}
<div class="page-title">
  {% if profileImage %}
    <h1 class="title minwidth">{{ title }}</h1>
    <img src="{{ profileImage }}" srcset="{{ profileImage }} 1x, {{ profileImage2x }} 2x" class="illustration" alt="{{ title }}" >
  {% else %}
    <h1 class="title">{{ title }}</h1>
  {% endif %}
</div>
{% if titleLinks %}
    <div class="page-title links">
        {% for link, href in titleLinks %}
            <a href="{{ href }}">{{ link }}</a>{% if not loop.last %} &bull;{% endif %}
        {% endfor %}
    </div>
{% endif %}
{% endif %}
{{ content | safe }}
