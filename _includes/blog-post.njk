---
layout: page.njk
---

{# This is the template for individual blog posts–it builds the front matter properties into the page #}

<section class="post">
  <p class="post-metadata">
    <strong>Posted:</strong> {{ date | date("yyyy-LL-dd") }}
    {% include "ail.njk" %}
    {% if tags.length > 1 %}
      <br /><strong>More: </strong>
      {%- for tag in tags -%}
        {%- if tag != "posts" -%}
          <a href="/archive/#{{ tag }}">{{ categories[tag].short or tag | capitalize }}</a>{% if not loop.last %}, {% endif %}
        {%- endif -%}
      {%- endfor -%}
    {% endif %}
  </p>
  {# Content from the body of the post markdown appears here #}
  {{ content | safe }}
  <div class="controls">
  {# The previous and next post data is added in .eleventy.js #}
  {% if prevPost.url %}
    <p>
      <strong>Previous post</strong>:
      <a class="previous" href="{{ prevPost.url }}">{{ prevPost.data.title }}</a>
    </p>
  {% endif %}
  {% if nextPost.url %}
    <p>
      <strong>Next post</strong>:
      <a class="next" href="{{ nextPost.url }}">{{ nextPost.data.title }}</a>
    </p>
  {% endif %}
  </div>
</section>
